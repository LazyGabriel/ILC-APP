PORT=5000
MONGO_URI=mongodb://localhost:27017/ilc-books
JWT_SECRET=your-secret-key-here

# Email (Nodemailer) — use Gmail App Password or SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Where order confirmation emails come FROM
EMAIL_FROM=ILC Books <books@ilc.cz>

# ILC admin email — receives order notifications
ADMIN_EMAIL=admin@ilc.cz

# Frontend URL (for tracking links in emails)
FRONTEND_URL=http://localhost:5173
